;; kotoba-lang/qa-governor — common QA governor actor (ADR-2607031100).
;; Pure .cljc rubric/governor/ledger + deterministic collectors, plus
;; qa-governor.operation: the langgraph-clj StateGraph wiring (a real LLM
;; scoring node remains a separate, not-yet-built follow-up).
{:paths ["src"]

 :deps {org.clojure/clojure {:mvn/version "1.12.0"}
        io.github.kotoba-lang/langgraph
        {:local/root "../langgraph"}}

 :aliases
 {;; offline workspace dev — pin transitive langchain (langgraph-clj's own
  ;; dep, kotoba-lang/langchain -- distinct from com-junkawasaki/langchain-clj)
  ;; to the local sibling checkout instead of a network git/sha fetch.
  :dev {:override-deps
        {io.github.kotoba-lang/langchain
         {:local/root "../langchain"}}}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]}
  ;; clj-kondo as a Clojars lib (no Homebrew/system install needed).
  :lint {:extra-deps {clj-kondo/clj-kondo {:mvn/version "2024.09.27"}}
         :main-opts ["-m" "clj-kondo.main" "--lint" "src" "test"]}}}
